# Local Control Plane environment — copy to .env.control-plane.local and fill in values.
# Source this file before running worker/api/smoke commands.
# This file is safe to commit. .env.control-plane.local is gitignored.
#
# Split model:
#   config/control_plane.local.yaml holds structure and behaviour (safe to version).
#   This file holds secrets and runtime knobs (never commit real values).

# ---------------------------------------------------------------------------
# Secrets (never commit real values)
# ---------------------------------------------------------------------------

# Plane API token (from Plane → Settings → API Tokens)
export PLANE_API_TOKEN='your-plane-api-token'

# GitHub token — option A: pull live from gh CLI (requires: gh auth login)
export GITHUB_TOKEN=$(awk '/oauth_token:/{print $2}' ~/.config/gh/hosts.yml)
# GitHub token — option B: classic PAT with repo scope
# export GITHUB_TOKEN='github_pat_...'
# GitHub token — option C: fine-grained PAT (per-repo scope)
# export GITHUB_TOKEN='github_pat_...'
# Per-repo token override (referenced by token_env in config yaml):
# export GITHUB_TOKEN_MYREPO='github_pat_...'

# ---------------------------------------------------------------------------
# Plane
# ---------------------------------------------------------------------------

export CONTROL_PLANE_PLANE_URL='http://localhost:8080'

# ---------------------------------------------------------------------------
# Execution controls
# ---------------------------------------------------------------------------
# Rolling budget windows protect against runaway execution costs.
# Skips are non-blocking: budget exhaustion is logged and treated as a valid
# outcome, not an error. Adjust these to match your API plan.

export CONTROL_PLANE_MAX_EXEC_PER_HOUR=10
export CONTROL_PLANE_MAX_EXEC_PER_DAY=50
export CONTROL_PLANE_MAX_RETRIES_PER_TASK=3

# Minimum remaining daily budget before proposal creation is suppressed.
export CONTROL_PLANE_MIN_REMAINING_EXEC_FOR_PROPOSALS=3

# Minimum watch interval floor (seconds). No watcher polls faster than this.
export CONTROL_PLANE_MIN_WATCH_INTERVAL_SECONDS=5

# Path to the execution-usage ledger (JSON). Tracks hourly/daily counters.
export CONTROL_PLANE_EXECUTION_USAGE_PATH='tools/report/control_plane/execution/usage.json'

# ---------------------------------------------------------------------------
# Watcher poll intervals (seconds)
# ---------------------------------------------------------------------------
# Lower values make the system more responsive but increase API call volume.

export CONTROL_PLANE_WATCH_INTERVAL_GOAL_SECONDS=30
export CONTROL_PLANE_WATCH_INTERVAL_TEST_SECONDS=60
export CONTROL_PLANE_WATCH_INTERVAL_IMPROVE_SECONDS=60
export CONTROL_PLANE_WATCH_INTERVAL_PROPOSE_SECONDS=120
# Review watcher polls GitHub PR reactions (👍/👀) and triggers revision loops.
export CONTROL_PLANE_WATCH_INTERVAL_REVIEW_SECONDS=60
# Legacy aliases (CONTROL_PLANE_{GOAL,TEST,IMPROVE,PROPOSE}_POLL_SECONDS) are
# still accepted as fallbacks but deprecated — use the names above instead.

# ---------------------------------------------------------------------------
# PR automation safety
# ---------------------------------------------------------------------------
# Set to 1 to enable dry-run mode: PR creation/merge is skipped and the
# intended action is logged instead. Useful for validating the automation
# path without actually touching GitHub PRs.
# export CONTROL_PLANE_PR_DRY_RUN=0

# ---------------------------------------------------------------------------
# Plane startup
# ---------------------------------------------------------------------------

export CONTROL_PLANE_PLANE_START_COMMAND='./deployment/plane/manage.sh up'
# Set to 1 to open the Plane URL in a browser on dev-up
export CONTROL_PLANE_PLANE_OPEN_BROWSER='0'

# ---------------------------------------------------------------------------
# Defaults
# ---------------------------------------------------------------------------

# Default repo key (must match a key in config yaml repos section)
export CONTROL_PLANE_DEFAULT_REPO='MyRepo'

# ---------------------------------------------------------------------------
# Paths & overrides
# ---------------------------------------------------------------------------

# Config file path override (default: config/control_plane.local.yaml)
# export CONTROL_PLANE_CONFIG='config/control_plane.local.yaml'
# Env file path override (default: .env.control-plane.local)
# export CONTROL_PLANE_ENV_FILE='.env.control-plane.local'

# ---------------------------------------------------------------------------
# API server
# ---------------------------------------------------------------------------

# Host and port for the local control-plane API.
# export CONTROL_PLANE_API_HOST='127.0.0.1'
# export CONTROL_PLANE_API_PORT=8787

# ---------------------------------------------------------------------------
# Housekeeping
# ---------------------------------------------------------------------------

# Number of days to retain old execution artifacts before cleanup.
# export CONTROL_PLANE_RETENTION_DAYS=1

# ---------------------------------------------------------------------------
# Provider configuration (generated by setup wizard)
# ---------------------------------------------------------------------------
# The variables below are written automatically by `control-plane.sh setup`.
# Hand-editing is possible but not recommended — rerun the wizard instead.
#
# export CONTROL_PLANE_PROVIDER_PREFERRED_SMART='claude'
# export CONTROL_PLANE_PROVIDER_PREFERRED_FAST='codex'
# export CONTROL_PLANE_ALLOWED_PROVIDERS='claude,codex'
# export CONTROL_PLANE_PROVIDER_HEADLESS_REQUIRED=0
# export CONTROL_PLANE_PROVIDER_CLAUDE_VERSION='...'
# export CONTROL_PLANE_PROVIDER_CODEX_VERSION='...'
# export CONTROL_PLANE_PROVIDER_GEMINI_VERSION='...'

# ---------------------------------------------------------------------------
# Dependency pinning (generated by setup wizard)
# ---------------------------------------------------------------------------
# export CONTROL_PLANE_PLANE_VERSION='...'
# export CONTROL_PLANE_PLANE_SETUP_URL='...'
# export CONTROL_PLANE_KODO_INSTALL_REF='...'
